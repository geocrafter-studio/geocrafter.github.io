---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Helpdesk from '../components/Helpdesk.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import Platforms from '../components/Platforms.astro';
import Datasets from '../components/Datasets.astro';
import Contact from '../components/Contact.astro';
import CTA from '../components/CTA.astro';
---

<BaseLayout title="Geocrafter - Geospatial Studio">
  <Header />
  <main>
    <Hero 
      title="GEOCRAFTER" 
      subtitle="We build your trust! Expert geospatial consulting and development services for modern cloud-native workflows."
    />
    <Helpdesk />
    <About />
    <Services />
    <Platforms />
    <Datasets />
    <Contact />
    <CTA />
  </main>
  <Footer />
</BaseLayout>
