---
---

<header class="fixed top-0 left-0 right-0 z-50 bg-brand-dark border-b border-neutral-800">
  <div class="container-custom">
    <nav class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center">
        <span class="font-orbitron text-sm lg:text-base text-white hover:text-brand-yellow tracking-widest whitespace-nowrap transition-colors">GEOCRAFTER - GEOSPATIAL STUDIO</span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        <a href="/datasets" class="font-sans text-sm text-white hover:text-brand-yellow transition-colors">
          Datasets
        </a>
        <a href="/expertise" class="font-sans text-sm text-white hover:text-brand-yellow transition-colors">
          Expertise
        </a>
        <a href="/craftfolio" class="font-sans text-sm text-white hover:text-brand-yellow transition-colors">
          Craftfolio
        </a>
        <a href="/helpdesk" class="font-sans text-sm text-white hover:text-brand-yellow transition-colors">
          Helpdesk
        </a>
        <a href="/#contact" class="btn-primary">
          Contact
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="md:hidden p-2 text-white">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-brand-charcoal border-t border-neutral-800">
    <div class="container-custom py-4 space-y-4">
      <a href="/datasets" class="block font-sans text-white hover:text-brand-yellow">
        Datasets
      </a>
      <a href="/expertise" class="block font-sans text-white hover:text-brand-yellow">
        Expertise
      </a>
      <a href="/craftfolio" class="block font-sans text-white hover:text-brand-yellow">
        Craftfolio
      </a>
      <a href="/helpdesk" class="block font-sans text-white hover:text-brand-yellow">
        Helpdesk
      </a>
      <a href="/#contact" class="block btn-primary text-center">
        Contact
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
