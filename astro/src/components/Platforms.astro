---
const platforms = [
  {
    name: "GeoNode",
    tagline: "Complete Spatial Data Infrastructure",
    description: "Full GeoNode installation, configuration, and maintenance. Custom themes, backups, and security hardening.",
    price: "Custom Quote"
  },
  {
    name: "Mergin Maps",
    tagline: "Mobile Field Data Collection",
    description: "Collaborative field data collection with offline capability. Server deployment and QGIS configuration.",
    price: "From €9/month"
  },
  {
    name: "GIS3W",
    tagline: "WebGIS Publishing Platform",
    description: "Publish QGIS projects as web mapping applications. User management and print layouts support.",
    price: "Custom Quote"
  }
];
---

<section id="platforms" class="section bg-white">
  <div class="container-custom">
    <div class="text-center mb-12">
      <h2 class="heading-display text-block-title text-brand-dark mb-4">PLATFORMS</h2>
      <p class="text-body text-neutral-600 max-w-2xl mx-auto">
        Managed hosting for open-source geospatial platforms on European infrastructure.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {platforms.map((platform) => (
        <div class="card-dark text-center group">
          <div class="w-16 h-16 bg-brand-yellow rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-brand-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2"></path>
            </svg>
          </div>
          <h3 class="font-display text-2xl text-brand-yellow mb-1">{platform.name}</h3>
          <p class="text-small text-neutral-400 uppercase tracking-wider mb-4">{platform.tagline}</p>
          <p class="text-body text-neutral-300 mb-4">{platform.description}</p>
          <p class="font-bold text-brand-yellow">{platform.price}</p>
        </div>
      ))}
    </div>
  </div>
</section>
