---
const services = [
  {
    title: "Python Geospatial Development",
    description: "Build robust geospatial data pipelines and applications using modern Python technologies.",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>`,
    tech: "Python, GeoPandas, Rasterio, Shapely, GDAL"
  },
  {
    title: "Earth Observation Pipelines",
    description: "Scalable satellite imagery processing using distributed computing frameworks.",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path></svg>`,
    tech: "Dask, Xarray, STAC, COG, Zarr"
  },
  {
    title: "Open Source GIS Consulting",
    description: "Expert guidance on implementing and optimizing open-source geospatial solutions.",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2"></path></svg>`,
    tech: "QGIS, PostGIS, GeoServer, MapServer"
  },
  {
    title: "Data Format Optimization",
    description: "Converting and optimizing geospatial data for cloud-native workflows.",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7"></path></svg>`,
    tech: "COG, GeoParquet, Zarr, OGC APIs"
  },
  {
    title: "Training & Workshops",
    description: "Customized training programs for your team on geospatial technologies.",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13"></path></svg>`,
    tech: "Python GIS, Dask, Cloud-native formats"
  },
  {
    title: "Web Mapping Development",
    description: "Interactive web mapping applications and spatial data visualization.",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3"></path></svg>`,
    tech: "OpenLayers, Leaflet, Mapbox"
  }
];
---

<section id="services" class="section bg-neutral-50">
  <div class="container-custom">
    <div class="text-center mb-12">
      <h2 class="heading-display text-block-title text-brand-dark mb-4">OUR SERVICES</h2>
      <p class="text-body text-neutral-600 max-w-2xl mx-auto">
        Expert geospatial consulting and development services for modern cloud-native workflows.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => (
        <div class="card group hover:shadow-card transition-all duration-300">
          <div class="w-12 h-12 bg-brand-yellow flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
            <Fragment set:html={service.icon} />
          </div>
          <h3 class="font-heading text-heading text-brand-dark mb-3">{service.title}</h3>
          <p class="text-body text-neutral-600 mb-4">{service.description}</p>
          <p class="text-small text-neutral-400 font-bold uppercase tracking-wider">{service.tech}</p>
        </div>
      ))}
    </div>
  </div>
</section>
